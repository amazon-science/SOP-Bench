            "video_id": {
              "type": "string",
              "description": "Unique identifier for the video",
              "pattern": "^vid_\\d{5}$"
            },
            "video_language": {
              "type": "string",
              "description": "Language of the video content"
            },
            "region": {
              "type": "string",
              "description": "Region code for the video"
            }
          },
          "required": [
            "video_id",
            "video_language",
            "region"
          ],
          "additionalProperties": false
        }
      }
    }
  },
  {
