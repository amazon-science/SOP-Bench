[
  {
    "toolSpec": {
      "name": "validateVideo",
      "description": "Validates video format and extracts technical metadata.",
      "inputSchema": {
        "json": {
          "type": "object",
          "properties": {
            "video_id": {
              "type": "string",
              "description": "Unique identifier for the video",
              "pattern": "^vid_\\d{5}$",
              "examples": [
                "vid_00010"
              ]
            },
            "video_path": {
              "type": "string",
              "description": "Path to the video file"
            }
          },
          "required": [
            "video_id",
            "video_path"
          ],
          "additionalProperties": false
        }
      }
    }
  },
  {
    "toolSpec": {
      "name": "assignReviewer",
