                    ],
                    "additionalProperties": false
                }
            }
        }
    },
    {
        "toolSpec": {
            "name": "executeTroubleshooting",
            "description": "Performs automated troubleshooting steps based on identified root causes, executing predefined resolution procedures such as modem resets and signal refreshes. Records timestamps and outcomes for traceability.",
            "inputSchema": {
                "json": {
                    "type": "object",
                    "properties": {
                        "account_id": {
                            "type": "string",
                            "description": "Customer's unique account identifier",
                            "pattern": "^[A-Z]{3}-[0-9]{5}$",
                            "examples": [
                                "ABC-12345"
                            ]
                        },
                        "session_token": {
                            "type": "string",
                            "description": "Valid authentication session token for the current troubleshooting session",
                            "examples": [
                                "SES-20250509-ABC12345-001"
                            ]
                        },
                        "root_causes": {
                            "type": "array",
                            "description": "List of identified root causes requiring troubleshooting",
                            "items": {
                                "type": "string"
                            },
                            "minItems": 1
                        }
                    },
                    "required": [
                        "account_id",
                        "session_token",
                        "root_causes"
                    ]
                }
            }
        }
    },
