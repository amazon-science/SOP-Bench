                            "type": "string",
                            "description": "Type of object detected in the video (e.g., 'road lanes', 'pedestrians', 'bicyclists')"
                        },
                        "predicted_iou": {
                            "type": "number",
                            "description": "Predicted Intersection over Union score for the segmentation",
                            "minimum": 0.0,
                            "maximum": 1.0
                        },
                        "segmentation_output_path": {
                            "type": "string",
                            "description": "File system path to the segmentation output files",
                            "pattern": "^/data/videos/.*\\.(binary|indices)$"
                        },
                        "object_detection_output_path": {
                            "type": "string",
