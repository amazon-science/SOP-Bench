                    "required": [
                        "video_id",
                        "video_path"
                    ],
                    "additionalProperties": false
                }
            }
        }
    },
    {
        "toolSpec": {
            "name": "performHumanValidation",
            "description": "Executes human-in-the-loop validation process for video annotations, managing multiple reviewer inputs and calculating inter-annotator agreement scores while ensuring compliance with minimum quality standards.",
            "inputSchema": {
                "json": {
                    "type": "object",
                    "properties": {
                        "video_id": {
                            "type": "string",
