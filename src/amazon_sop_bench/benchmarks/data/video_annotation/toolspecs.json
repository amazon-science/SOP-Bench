[
    {
        "toolSpec": {
            "name": "validateVideoFormat",
            "description": "Validates video format and metadata against required specifications for autonomous vehicle perception system training, ensuring compliance with format, resolution, frame rate, and environmental requirements.",
            "inputSchema": {
                "json": {
                    "type": "object",
                    "properties": {
                        "video_id": {
                            "type": "string",
                            "description": "Unique identifier for the video to be validated",
                            "pattern": "^vid_\\d{5}$",
                            "examples": [
                                "vid_00010"
                            ]
                        }
                    },
                    "required": [
                        "video_id"
                    ],
                    "additionalProperties": false
                }
            }
        }
    },
    {
        "toolSpec": {
            "name": "validateLidarData",
            "description": "Validates LiDAR data completeness, synchronization, and associated metadata according to SOP requirements. Ensures point cloud data is properly aligned with video frames and meets technical specifications for autonomous vehicle perception.",
            "inputSchema": {
                "json": {
                    "type": "object",
                    "properties": {
                        "video_id": {
                            "type": "string",
                            "description": "Unique identifier for the video sequence",
                            "pattern": "^vid_[0-9]{5}$"
                        },
                        "video_path": {
                            "type": "string",
                            "description": "Full path to the video file for which LiDAR data needs to be validated",
                            "pattern": "^/data/videos/.*\\.(mp4|avi|mov)$"
                        }
                    },
                    "required": [
                        "video_id",
                        "video_path"
                    ],
                    "additionalProperties": false
                }
            }
        }
    },
    {
        "toolSpec": {
            "name": "executeSegmentation",
            "description": "Performs segmentation processing on detected objects in video data, generating segmentation masks and validating against quality thresholds as specified in the SOP.",
            "inputSchema": {
                "json": {
                    "type": "object",
                    "properties": {
                        "video_id": {
                            "type": "string",
                            "description": "Unique identifier for the video being processed",
                            "pattern": "^vid_\\d{5}$"
                        },
                        "predicted_object": {
                            "type": "string",
                            "description": "The type of object detected in the previous detection step",
                            "examples": [
                                "road lanes",
                                "pedestrians",
                                "bicyclists",
                                "street markings"
                            ]
                        },
                        "object_detection_output_path": {
                            "type": "string",
                            "description": "File system path to the object detection results",
                            "pattern": "^/data/videos/.*\\.(json|xml)$"
                        },
                        "output_format_object_detection": {
                            "type": "string",
                            "description": "Format of the object detection output file",
                            "enum": [
                                "json",
                                "xml"
                            ]
                        }
                    },
                    "required": [
                        "video_id",
                        "predicted_object",
                        "object_detection_output_path",
                        "output_format_object_detection"
                    ],
                    "additionalProperties": false
                }
            }
        }
    },
    {
