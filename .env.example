# AWS Configuration
# Copy this file to .env and fill in your values

# AWS Region (default: us-west-2)
AWS_REGION=us-west-2

# AWS Bedrock Model IDs
# "claude 3.5 sonnet v2": "us.anthropic.claude-3-5-sonnet-20241022-v2:0",  
# "claude 3.7 sonnet": "us.anthropic.claude-3-7-sonnet-20250219-v1:0",
# "claude 4 opus": "us.anthropic.claude-opus-4-20250514-v1:0",
# "claude 4 sonnet": "us.anthropic.claude-sonnet-4-20250514-v1:0",
# "claude 4.1 opus": "us.anthropic.claude-opus-4-1-20250805-v1:0",
# "claude 4.5 haiku": "us.anthropic.claude-haiku-4-5-20251001-v1:0"
# "claude 4.5 sonnet": "us.anthropic.claude-sonnet-4-5-20250929-v1:0"
# "claude 4.5 opus": "us.anthropic.claude-opus-4-5-20251101-v1:0"
# "gpt 120b": "us.openai.gpt-oss-120b-1:0",
# "gpt 20b": "us.openai.gpt-oss-20b-1:0",
# "deepseek r1": "us.deepseek.r1-v1:0",
# "llama 3.3 70b": "meta.llama3-3-70b-instruct-v1:0"
# "llama 4 maverick 17b": "meta.llama4-maverick-17b-instruct-v1:0"
# "llama 4 scout 17b": "meta.llama4-scout-17b-instruct-v1:0"

AWS_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# AWS IAM Role ARN (optional, for cross-account access)
# Example: arn:aws:iam::123456789012:role/BedrockAccessRole
AWS_ROLE_ARN=

# Model Parameters (optional overrides)
TEMPERATURE=0.5
MAX_TOKENS=8192

# Evaluation Settings (optional)
OUTPUT_DIR=./results
SAVE_TRACES=true

# Logging (optional)
LOG_LEVEL=INFO
